<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F7F8"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/buttonPreviousDay"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:gravity="center"
            android:text="‹"
            android:textColor="#222222"
            android:textSize="30sp" />

        <TextView
            android:id="@+id/textSelectedDate"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="2026-07-06 周一"
            android:textColor="#222222"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/buttonNextDay"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:gravity="center"
            android:text="›"
            android:textColor="#222222"
            android:textSize="30sp" />

        <Button
            android:id="@+id/buttonStatistic"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:minWidth="0dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="统计"
            android:textSize="14sp" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:text="今日打卡"
        android:textColor="#222222"
        android:textSize="17sp"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/layoutHabitList"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="#FFFFFF"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingTop="6dp"
        android:paddingEnd="14dp"
        android:paddingBottom="6dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:text="运动"
                android:textColor="#222222"
                android:textSize="16sp" />

            <CheckBox
                android:id="@+id/checkExercise"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:buttonTint="#996699"
                android:gravity="center" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:text="阅读"
                android:textColor="#222222"
                android:textSize="16sp" />

            <CheckBox
                android:id="@+id/checkReading"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:buttonTint="#996699"
                android:gravity="center" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:text="思维"
                android:textColor="#222222"
                android:textSize="16sp" />

            <CheckBox
                android:id="@+id/checkThinking"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:buttonTint="#996699"
                android:gravity="center" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:text="口语"
                android:textColor="#222222"
                android:textSize="16sp" />

            <CheckBox
                android:id="@+id/checkSpeaking"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:buttonTint="#996699"
                android:gravity="center" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:text="睡眠"
                android:textColor="#222222"
                android:textSize="16sp" />

            <CheckBox
                android:id="@+id/checkSleep"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:buttonTint="#996699"
                android:gravity="center" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:text="随记"
        android:textColor="#222222"
        android:textSize="17sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/editNote"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_weight="1"
        android:background="#FFFFFF"
        android:gravity="top|start"
        android:hint="今日复盘、心得、待改进事项"
        android:inputType="textMultiLine"
        android:minHeight="120dp"
        android:padding="14dp"
        android:scrollbars="vertical"
        android:textColor="#222222"
        android:textColorHint="#8A8A8A"
        android:textSize="15sp" />

    <Button
        android:id="@+id/buttonSaveRecord"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="14dp"
        android:text="保存当日记录"
        android:textSize="16sp" />
</LinearLayout>
