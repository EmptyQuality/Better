<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Quality" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/quality_primary</item>
        <item name="colorSecondary">@color/quality_primary_light</item>
        <item name="colorSurface">@color/quality_surface</item>
        <item name="colorOnPrimary">#111827</item>
        <item name="android:colorAccent">@color/quality_primary</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@color/quality_background</item>
    </style>

    <style name="Theme.Quality" parent="Base.Theme.Quality" />

    <style name="Theme.Quality.DatePicker" parent="Theme.Material3.DayNight.Dialog.Alert">
        <item name="colorPrimary">@color/quality_primary</item>
        <item name="colorSecondary">@color/quality_primary_light</item>
        <item name="colorOnPrimary">#111827</item>
        <item name="android:colorAccent">@color/quality_primary</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>
</resources>
